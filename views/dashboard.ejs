<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard</title>
    <link rel="stylesheet" href="/public/style.css" />
  </head>
  <body>
    <main class="center-wrapper">
      <section class="card">
        <h1>Dashboard</h1>
        <p class="subtitle">Selamat datang, <strong><%= user.username %></strong></p>

        <div class="info-box">
          Session aktif. Jika logout, akses ke dashboard akan diproteksi dan diarahkan ke login.
        </div>

        <form action="/logout" method="POST">
          <button type="submit">Logout</button>
        </form>
      </section>
    </main>
  </body>
</html>
